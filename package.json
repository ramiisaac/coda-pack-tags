{
  "name": "coda_tags",
  "version": "1.0.0",
  "description": "A Coda Pack that extracts meaningful tags from text by filtering out common words and noise",
  "license": "MIT",
  "author": "Rami Isaac <raisaac@icloud.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ramiisaac/coda_tags"
  },
  "homepage": "https://github.com/ramiisaac/coda_tags#readme",
  "bugs": {
    "url": "https://github.com/ramiisaac/coda_tags/issues"
  },
  "keywords": [
    "coda",
    "pack",
    "text",
    "tags",
    "nlp",
    "filter"
  ],
  "type": "commonjs",
  "main": "pack.js",
  "scripts": {
    "build": "tsc",
    "test": "mocha",
    "typecheck": "tsc --noEmit",
    "validate": "coda validate pack.ts",
    "lint": "eslint pack.ts --ext .ts",
    "lint:fix": "eslint pack.ts --ext .ts --fix",
    "format": "prettier --write '*.{ts,tsx,js,jsx,json,md}'",
    "upload": "coda upload pack.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@codahq/packs-sdk": "^1.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/chai": "^4.3.16",
    "@types/content-disposition": "^0.5.8",
    "@types/jsrsasign": "^10.5.15",
    "@types/luxon": "^3.4.2",
    "@types/mime-types": "^2.1.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.4",
    "@types/sinon": "^17.0.3",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "chai": "^4.5.0",
    "eslint": "^9.20.1",
    "eslint-plugin-ban": "^2.0.0",
    "eslint-plugin-filenames": "^1.3.2",
    "eslint-plugin-local": "^6.0.0",
    "eslint-plugin-prefer-let": "^4.0.0",
    "eslint-plugin-prettier": "^5.2.3",
    "json-schema": "^0.4.0",
    "mocha": "^11.1.0",
    "prettier": "^3.5.1",
    "sinon": "^19.0.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.12.3"
}
